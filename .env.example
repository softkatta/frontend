# Local development — copy to .env
# Leave VITE_API_HOSTNAME empty to use Vite dev proxy; set full URL to call API directly.
VITE_APP_NAME=SoftKatta Solutions
VITE_APP_ENV=development
VITE_SITE_URL=https://softkatta.in
VITE_API_HOSTNAME=
VITE_API_BASE_URL=/api/v1
VITE_API_TIMEOUT_MS=10000
VITE_STORAGE_SECRET=change-me-local-dev-secret
